    - name: Checkout
      uses: actions/checkout@v4
      with:
        fetch-depth: 0

    # -----------------------------------------------------------------------
    # 1. Extract JIRA ticket key from the branch name (e.g. PROJ-123-my-feat)
    #    Branches prefixed with NOJIRA are explicitly skipped.
    # -----------------------------------------------------------------------
    - name: Extract JIRA ticket from branch name
      id: jira
      run: |
        BRANCH="${{ github.head_ref }}"
        if echo "$BRANCH" | grep -qiE '^NOJIRA'; then
          echo "found=false" >> $GITHUB_OUTPUT
          echo "⏭️  Branch '$BRANCH' has NOJIRA prefix — skipping JIRA steps"
          exit 0
        fi
        TICKET=$(echo "$BRANCH" | grep -oE '[A-Z]{2,10}-[0-9]+' | head -1)
        if [ -n "$TICKET" ]; then
          echo "found=true"  >> $GITHUB_OUTPUT
          echo "ticket=$TICKET" >> $GITHUB_OUTPUT
          echo "✅ Found JIRA ticket: $TICKET"
        else
          echo "found=false" >> $GITHUB_OUTPUT
          echo "⚠️  No JIRA ticket key found in branch: $BRANCH — skipping JIRA steps"
        fi

    # -----------------------------------------------------------------------
    # 2. Fetch ticket details from JIRA REST API
    # -----------------------------------------------------------------------
    - name: Fetch JIRA ticket details
      id: jira-data
      if: steps.jira.outputs.found == 'true'
      env:
        JIRA_BASE_URL: ${{ secrets.JIRA_BASE_URL }}
        JIRA_USER: ${{ secrets.JIRA_USER }}
        JIRA_TOKEN: ${{ secrets.JIRA_TOKEN }}
      run: |
        TICKET="${{ steps.jira.outputs.ticket }}"
        RESPONSE=$(curl -sf -u "$JIRA_USER:$JIRA_TOKEN" \
          "$JIRA_BASE_URL/rest/api/3/issue/$TICKET?fields=summary,description,status,acceptance_criteria" \
          -H "Accept: application/json")

        SUMMARY=$(echo "$RESPONSE" | jq -r '.fields.summary // "N/A"')
        STATUS=$(echo "$RESPONSE"  | jq -r '.fields.status.name // "N/A"')

        # ADF description → plain text (best-effort first paragraph)
        DESCRIPTION=$(echo "$RESPONSE" | \
          jq -r '[.fields.description.content[]? | .. | .text? // empty] | join(" ")' 2>/dev/null \
          || echo "No description available")

        echo "summary=$SUMMARY"   >> $GITHUB_OUTPUT
        echo "status=$STATUS"     >> $GITHUB_OUTPUT
        # Write to file to avoid env-size limits on long descriptions
        printf '%s' "$DESCRIPTION" > /tmp/jira_description.txt

    # -----------------------------------------------------------------------
    # 3. Append JIRA context + AI review instruction to the PR description
    #    (only when the section is not already present)
    # -----------------------------------------------------------------------
    - name: Append JIRA context to PR description
      id: pr-update
      if: steps.jira.outputs.found == 'true'
      uses: actions/github-script@v7
      with:
        script: |
          const fs      = require('fs');
          const ticket  = '${{ steps.jira.outputs.ticket }}';
          const summary = `${{ steps.jira-data.outputs.summary }}`;
          const status  = '${{ steps.jira-data.outputs.status }}';
          const baseUrl = '${{ secrets.JIRA_BASE_URL }}';
          const desc    = fs.readFileSync('/tmp/jira_description.txt', 'utf8').trim();

          const { data: pr } = await github.rest.pulls.get({
            owner: context.repo.owner,
            repo:  context.repo.repo,
            pull_number: context.issue.number,
          });

          const marker = `<!-- workflow-sync:jira-section -->`;
          if ((pr.body || '').includes(marker)) {
            console.log('JIRA section already present — skipping update');
            core.setOutput('jira_requirements', desc);
            return;
          }

          const jiraSection = [
            marker,
            `## 🎫 JIRA: [${ticket}](${baseUrl}/browse/${ticket})`,
            `| Field | Value |`,
            `|-------|-------|`,
            `| **Summary** | ${summary} |`,
            `| **Status**  | ${status}  |`,
            ``,
            `### Requirements`,
            desc,
            ``,
            `---`,
            `> **<!-- AI review instruction -->**`,
            `> Review the code changes in this PR and verify they satisfy every requirement`,
            `> listed in the JIRA ticket above. Call out any acceptance criteria that are`,
            `> missing, incomplete, or incorrectly implemented.`,
          ].join('\n');

          await github.rest.pulls.update({
            owner: context.repo.owner,
            repo:  context.repo.repo,
            pull_number: context.issue.number,
            body: pr.body ? `${pr.body}\n\n${jiraSection}` : jiraSection,
          });
          console.log('✅ PR description updated with JIRA context');
          core.setOutput('jira_requirements', desc);
